{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Takit",
  "version": "0.1.0",
  "identifier": "com.takit.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Takit",
        "label": "main",
        "width": 540,
        "height": 700,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Lightweight video & audio downloader",
    "longDescription": "Takit is a lightweight, cross-platform video and audio downloader. Paste a link, choose video or audio, and download. It runs quietly in the system tray and uses very little memory.",
    "copyright": "Copyright © 2026 Takit contributors",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {}
}
